{
  "manifest_version": 3,
  "name": "SyncStream",
  "version": "1.0.4",
  "description": "Sync YouTube playback with a friend over PeerJS (watch together remotely).",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["https://0.peerjs.com/*", "wss://0.peerjs.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SyncStream"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://youtu.be/*",
        "https://www.youtube-nocookie.com/*"
      ],
      "js": ["lib/peerjs.min.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
